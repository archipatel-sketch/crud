{
  "name": "archipatel-sketch/crud",
  "description": "Dynamic CRUD generator for Laravel",
  "license": "MIT",
  "version": "1.0.1",
  "authors": [
    {
      "name": "archipatel-sketch",
      "email": "archi.patel@webbycrown.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "barryvdh/laravel-dompdf": "*",
    "maatwebsite/excel": "*"
  },
  "autoload": {
    "files": [
      "src/Helpers/helpers.php"
    ],
    "psr-4": {
      "ArchipatelSketch\\Crud\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "ArchipatelSketch\\Crud\\Providers\\CrudServiceProvider"
      ],
      "aliases": {}
    }
  },
  "minimum-stability": "stable"
}
